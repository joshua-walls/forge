{
  "name": "forge",
  "version": "2.0.1",
  "description": "Define your vault's structure and let Forge enforce it — lint, normalize, patch, and maintain with confidence.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "build": "npm run typecheck && node esbuild.config.mjs production",
    "lint:obsidian": "npm exec -- eslint --no-warn-ignored \"src/**/*.ts\" \"manifest.json\" \"styles.css\"",
    "test": "tsc -p tsconfig.test.json && node --test .tmp-test/tests/*.test.js tests/*.test.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [],
  "author": "Joshua Walls",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.1",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.60.1"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
