{
  "name": "@forge/core",
  "version": "0.1.0",
  "description": "Host-independent Forge logic shared by Obsidian and VS Code adapters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "npm run clean && tsc -p tsconfig.test.json && node --test .tmp-test/tests/*.test.js"
  },
  "keywords": [
    "forge",
    "markdown",
    "validation"
  ],
  "author": "Joshua Walls",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^10.4.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.60.1"
  }
}
